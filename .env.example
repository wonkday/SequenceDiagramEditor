# Server
PORT=8001
CONTAINER_NAME=seq-diag-editor
IMAGE_NAME=seq-diag-editor

# Kroki
KROKI_PORT=8000
KROKI_CONTAINER=kroki-plantuml
KROKI_IMAGE=yuzutech/kroki
#KROKI_URL=http://ilcepoc3503:8000/plantuml/svg

# PlantUML limit size
PLANTUML_LIMIT_SIZE=16384

# Sharing
SHARE_TTL_DAYS=5
SHARE_MAX_FILES=100
SHARE_MAX_SIZE_MB=20

# Upstash Redis (leave blank for local filesystem storage)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Proxy (leave blank if not behind proxy)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

{
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/*.js": {
      "includeFiles": "lib/**"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/puml.html" },
    { "source": "/mermaid", "destination": "/mermaid.html" },
    { "source": "/gliffy", "destination": "/gliffy.html" },
    { "source": "/api/(.*)", "destination": "/api/index.js" }
  ]
}
